# Model to serve (see README for recommendations per GPU count)
MODEL=Qwen/Qwen3.5-35B-A3B

# Number of GPUs for tensor parallelism
GPU_COUNT=1

# Max context length (reduce if running out of VRAM)
MAX_MODEL_LEN=65536

# GPU memory utilization (0.0-1.0)
GPU_MEM_UTIL=0.92

# HuggingFace token (needed for gated models)
HF_TOKEN=

# HuggingFace cache directory (models are cached here)
HF_CACHE=~/.cache/huggingface

# Port configuration
VLLM_PORT=8000
LITELLM_PORT=4000

# Attention backend
VLLM_ATTENTION_BACKEND=FLASHINFER
